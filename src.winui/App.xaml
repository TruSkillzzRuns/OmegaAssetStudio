<Application
    x:Class="OmegaAssetStudio.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
                <Setter Property="PlaceholderForeground" Value="{ThemeResource OmegaAssetStudio.TextSecondaryBrush}" />
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="ToggleSwitch">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="RadioButton">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="HyperlinkButton">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.AccentBrush}" />
            </Style>
            <Style TargetType="AppBarButton">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="NavigationViewItem">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}" />
            </Style>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="{ThemeResource OmegaAssetStudio.DarkSurfaceTextColor}" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="{ThemeResource OmegaAssetStudio.DarkSurfaceTextColor}" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="{ThemeResource OmegaAssetStudio.DarkSurfaceTextColor}" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="{ThemeResource OmegaAssetStudio.DarkSurfaceTextColor}" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundPressed" Color="{ThemeResource OmegaAssetStudio.DarkSurfaceTextColor}" />
            <Style TargetType="TabViewItem">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="PivotItem">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            </Style>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceDictionary Source="ms-appx:///Resources/Themes/Light.xaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceDictionary Source="ms-appx:///Resources/Themes/Dark.xaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
