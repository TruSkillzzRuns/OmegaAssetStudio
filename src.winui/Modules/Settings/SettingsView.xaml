<Page
    x:Class="OmegaAssetStudio.WinUI.Modules.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:OmegaAssetStudio.WinUI.Modules.Settings"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource OmegaAssetStudio.PageBackgroundBrush}">
        <StackPanel
            Width="480"
            Margin="32"
            Spacing="16"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <TextBlock
                Text="Settings"
                FontSize="34"
                FontWeight="SemiBold"
                Foreground="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
            <TextBlock
                Text="Theme System"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{ThemeResource OmegaAssetStudio.TextSecondaryBrush}" />
            <Border
                Padding="20"
                Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Application Theme"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource OmegaAssetStudio.TextPrimaryBrush}" />
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}"
                        OffContent="Light"
                        OnContent="Dark" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ThemeLabel, Mode=OneWay}"
                        Foreground="{ThemeResource OmegaAssetStudio.TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
