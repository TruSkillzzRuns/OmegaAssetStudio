<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.ShaderInspector.ShaderMetadataControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="12"
            CornerRadius="10"
            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}"
            BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
            BorderThickness="1">
        <StackPanel Spacing="4">
            <TextBlock Text="Shader Metadata" FontWeight="SemiBold" />
            <TextBlock Text="{Binding SelectedShader.Name}" />
            <TextBlock Opacity="0.7" Text="{Binding SelectedShader.SourcePath}" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>

