<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.ShaderInspector.ShaderInspectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OmegaAssetStudio.WinUI.Modules.MaterialEditor.ShaderInspector"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Shader Inspector" FontSize="22" FontWeight="SemiBold" />
        <StackPanel Grid.Row="0" Margin="0,32,0,0" Spacing="4">
            <TextBlock Text="{Binding SelectedShaderSummaryText}" Opacity="0.75" />
            <TextBlock Text="{Binding PermutationCountText}" Opacity="0.75" />
            <TextBlock Text="{Binding SelectedPermutationSummaryText}" Opacity="0.75" TextWrapping="Wrap" />
        </StackPanel>
        <Grid Grid.Row="1" ColumnDefinitions="*,360" ColumnSpacing="12">
            <Border Padding="12"
                    CornerRadius="12"
                    Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                    BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Permutations" FontWeight="SemiBold" />
                    <ListView ItemsSource="{Binding Permutations}" SelectedItem="{Binding SelectedPermutation, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Opacity="0.7" Text="{Binding Value}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
            <local:ShaderMetadataControl Grid.Column="1" />
        </Grid>
    </Grid>
</UserControl>

