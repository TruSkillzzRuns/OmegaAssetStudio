<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.ColorVariantGenerator.ColorVariantGeneratorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OmegaAssetStudio.WinUI.Modules.MaterialEditor.ColorVariantGenerator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Color Variant Generator" FontSize="22" FontWeight="SemiBold" />
        <StackPanel Grid.Row="0" Margin="0,32,0,0" Spacing="4">
            <TextBlock Text="{Binding SelectedMaterialSummaryText}" Opacity="0.75" />
            <TextBlock Text="{Binding VariantCountText}" Opacity="0.75" />
            <TextBlock Text="{Binding SelectedVariantSummaryText}" Opacity="0.75" TextWrapping="Wrap" />
        </StackPanel>
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <local:ColorVariantPaletteControl />
            <Border Grid.Column="1"
                    Padding="12"
                    CornerRadius="12"
                    Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                    BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Variant Preview" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" Opacity="0.75" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

