<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.ShaderVariantTester.ShaderVariantListControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="12"
            CornerRadius="10"
            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}"
            BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
            BorderThickness="1">
        <StackPanel Spacing="8">
            <TextBlock Text="Shader Variants" FontWeight="SemiBold" />
            <ListView ItemsSource="{Binding Variants}" SelectedItem="{Binding SelectedPermutation, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Name}" />
                            <TextBlock Opacity="0.7" Text="{Binding Value}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Border>
</UserControl>

