<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialOverrideTool.MaterialOverrideView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialOverrideTool"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Material Override Tool" FontSize="22" FontWeight="SemiBold" />
        <StackPanel Grid.Row="0" Margin="0,32,0,0" Spacing="4">
            <TextBlock Text="{Binding SelectedMaterialSummaryText}" Opacity="0.75" />
            <TextBlock Text="{Binding ProfileCountText}" Opacity="0.75" />
            <TextBlock Text="{Binding SelectedProfileSummaryText}" Opacity="0.75" TextWrapping="Wrap" />
        </StackPanel>
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <local:OverrideProfileListControl />
            <local:OverrideParameterControl Grid.Column="1" />
        </Grid>
    </Grid>
</UserControl>

