<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.Rendering.MaterialPreviewHost"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <SwapChainPanel x:Name="PreviewPanel"
                        PointerPressed="PreviewPanel_PointerPressed"
                        PointerMoved="PreviewPanel_PointerMoved"
                        PointerReleased="PreviewPanel_PointerReleased"
                        PointerCanceled="PreviewPanel_PointerCanceled"
                        PointerWheelChanged="PreviewPanel_PointerWheelChanged" />

        <Border
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="12"
            Padding="10"
            CornerRadius="8"
            MaxWidth="360">
            <TextBlock
                Text="{Binding DiagnosticsText, ElementName=Root}"
                TextWrapping="WrapWholeWords" />
        </Border>
    </Grid>
</UserControl>

