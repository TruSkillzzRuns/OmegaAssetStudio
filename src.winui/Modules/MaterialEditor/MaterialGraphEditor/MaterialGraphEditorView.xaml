<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialGraphEditor.MaterialGraphEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialGraphEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="6">
            <TextBlock Text="Material Graph Editor" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusText}" Opacity="0.75" />
            <TextBlock Text="{Binding NodeCountText}" Opacity="0.75" />
            <TextBlock Text="{Binding ConnectionCountText}" Opacity="0.75" />
            <TextBlock Text="{Binding SelectedNodeSummaryText}" Opacity="0.75" TextWrapping="Wrap" />
        </StackPanel>
        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="12">
            <Border Padding="12"
                    CornerRadius="12"
                    Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                    BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Nodes" FontWeight="SemiBold" />
                    <ListView ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedNode, Mode=TwoWay}" HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <local:MaterialGraphNodeControl />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
            <local:MaterialGraphCanvasControl Grid.Column="1" />
        </Grid>
    </Grid>
</UserControl>

