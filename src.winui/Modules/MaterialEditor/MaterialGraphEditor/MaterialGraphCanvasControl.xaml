<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialGraphEditor.MaterialGraphCanvasControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="12"
            CornerRadius="10"
            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}"
            BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
            BorderThickness="1">
        <StackPanel Spacing="8">
            <TextBlock Text="Graph Canvas" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding Nodes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8"
                                CornerRadius="6"
                                Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                <TextBlock Opacity="0.7" Text="{Binding NodeType}" />
                                <TextBlock Opacity="0.7" Text="{Binding NodeId}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>

