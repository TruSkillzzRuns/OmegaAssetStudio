<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialGraphEditor.MaterialGraphNodeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="8"
            CornerRadius="6"
            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}"
            BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
            BorderThickness="1">
        <StackPanel>
            <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
            <TextBlock Opacity="0.7" Text="{Binding NodeType}" />
        </StackPanel>
    </Border>
</UserControl>

