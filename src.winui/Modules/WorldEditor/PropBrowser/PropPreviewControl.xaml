<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.WorldEditor.PropBrowser.PropPreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Prop Inspector" />
            <TextBlock Opacity="0.78"
                       TextWrapping="Wrap"
                       Text="Selected prop metadata and placement details." />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="Name" />
            <TextBlock Text="{x:Bind ViewModel.SelectedPropName, Mode=OneWay}"
                       TextWrapping="Wrap" />

            <TextBlock Text="Path" />
            <TextBlock Text="{x:Bind ViewModel.SelectedPropPath, Mode=OneWay}"
                       TextWrapping="Wrap" />

            <TextBlock Text="Transform" />
            <TextBlock Text="{x:Bind ViewModel.SelectedPropTransform, Mode=OneWay}"
                       TextWrapping="Wrap" />

            <TextBlock Text="Category" />
            <TextBlock Text="{x:Bind ViewModel.SelectedPropCategory, Mode=OneWay}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>

