<Page
    x:Class="OmegaAssetStudio.WinUI.Modules.WorldEditor.WorldEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editor="using:OmegaAssetStudio.WinUI.Modules.WorldEditor.WorldGeometryEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prop="using:OmegaAssetStudio.WinUI.Modules.WorldEditor.PropBrowser"
    xmlns:viewer="using:OmegaAssetStudio.WinUI.Modules.WorldEditor.WorldGeometryViewer"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock FontSize="32"
                       FontWeight="SemiBold"
                       Text="World Editor" />
            <TextBlock Opacity="0.82"
                       TextWrapping="Wrap"
                       Text="World geometry, props, collision, navmesh, lighting, triggers, and minimap tools live here." />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="16"
                CornerRadius="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SourcePathTextBox"
                         Header="Source UPK"
                         PlaceholderText="Enter or paste a UPK path to load World Editor data." />

                <Button Grid.Column="1"
                        Content="Load World Data"
                        VerticalAlignment="Bottom"
                        Click="LoadWorldData_Click" />
            </Grid>
        </Border>

        <TabView Grid.Row="2"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 TabWidthMode="SizeToContent">

            <TabViewItem Header="Preview">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="World Zones" />
                                <TextBlock Opacity="0.78"
                                           TextWrapping="Wrap"
                                           Text="Inspect loaded zone metadata and summaries." />
                            </StackPanel>

                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind PreviewViewModel.Zones, Mode=OneWay}"
                                      SelectedItem="{x:Bind PreviewViewModel.SelectedZone, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="4" Padding="0,4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding WorldPath}"
                                                       Opacity="0.72"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Zone Summary" />
                            <TextBlock Text="{x:Bind PreviewViewModel.SelectedZoneSummary, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Opacity="0.78"
                                       Text="{x:Bind PreviewViewModel.StatusText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Geometry">
                <viewer:WorldGeometryViewerView />
            </TabViewItem>

            <TabViewItem Header="Geometry Editor">
                <editor:WorldGeometryEditorView />
            </TabViewItem>

            <TabViewItem Header="Props">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <prop:PropListControl ViewModel="{x:Bind ViewModel, Mode=OneWay}" />
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <prop:PropPreviewControl ViewModel="{x:Bind ViewModel, Mode=OneWay}" />
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Collision">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Collision Volumes" />
                                <TextBlock Opacity="0.78"
                                           TextWrapping="Wrap"
                                           Text="Load and inspect collision volumes from the selected world package." />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Spacing="8">
                                <Button Content="Load Collision"
                                        Click="LoadWorldData_Click" />
                                <TextBlock Text="{x:Bind CollisionViewModel.StatusText, Mode=OneWay}"
                                           Opacity="0.78"
                                           TextWrapping="Wrap" />
                                <ListView ItemsSource="{x:Bind CollisionViewModel.CollisionVolumes, Mode=OneWay}"
                                          SelectedItem="{x:Bind CollisionViewModel.SelectedCollision, Mode=TwoWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4" Padding="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ShapeType}" Opacity="0.72" />
                                                <TextBlock Text="{Binding BoundsText}" Opacity="0.72" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Collision Inspector" />
                            <TextBlock Text="{x:Bind CollisionViewModel.SelectedCollisionName, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind CollisionViewModel.SelectedCollisionShapeType, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind CollisionViewModel.SelectedCollisionTransformText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind CollisionViewModel.SelectedCollisionBoundsText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Navmesh">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Navmesh Layers" />
                                <TextBlock Opacity="0.78"
                                           TextWrapping="Wrap"
                                           Text="Load and inspect navigation meshes and pathing layers." />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Spacing="8">
                                <Button Content="Load Navmesh"
                                        Click="LoadWorldData_Click" />
                                <TextBlock Text="{x:Bind NavmeshViewModel.StatusText, Mode=OneWay}"
                                           Opacity="0.78"
                                           TextWrapping="Wrap" />
                                <ListView ItemsSource="{x:Bind NavmeshViewModel.NavmeshLayers, Mode=OneWay}"
                                          SelectedItem="{x:Bind NavmeshViewModel.SelectedNavmesh, Mode=TwoWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4" Padding="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding PolygonCount}" Opacity="0.72" />
                                                <TextBlock Text="{Binding BoundsText}" Opacity="0.72" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Navmesh Inspector" />
                            <TextBlock Text="{x:Bind NavmeshViewModel.SelectedNavmeshName, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind NavmeshViewModel.SelectedNavmeshPolygonCount, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind NavmeshViewModel.SelectedNavmeshBoundsText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind NavmeshViewModel.SelectedNavmeshNotes, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Lighting">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Light Probes" />
                                <TextBlock Opacity="0.78"
                                           TextWrapping="Wrap"
                                           Text="Inspect color, intensity, and position data for lighting probes." />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Spacing="8">
                                <Button Content="Load Lighting"
                                        Click="LoadWorldData_Click" />
                                <TextBlock Text="{x:Bind LightingViewModel.StatusText, Mode=OneWay}"
                                           Opacity="0.78"
                                           TextWrapping="Wrap" />
                                <ListView ItemsSource="{x:Bind LightingViewModel.LightProbes, Mode=OneWay}"
                                          SelectedItem="{x:Bind LightingViewModel.SelectedLightProbe, Mode=TwoWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4" Padding="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ColorText}" Opacity="0.72" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding PositionText}" Opacity="0.72" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Lighting Inspector" />
                            <TextBlock Text="{x:Bind LightingViewModel.SelectedLightProbeName, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind LightingViewModel.SelectedLightProbeColorText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind LightingViewModel.SelectedLightProbeIntensityText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind LightingViewModel.SelectedLightProbePositionText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Triggers">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Trigger Volumes" />
                                <TextBlock Opacity="0.78"
                                           TextWrapping="Wrap"
                                           Text="Inspect trigger types, bounds, and attached scripts." />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Spacing="8">
                                <Button Content="Load Triggers"
                                        Click="LoadWorldData_Click" />
                                <TextBlock Text="{x:Bind TriggerViewModel.StatusText, Mode=OneWay}"
                                           Opacity="0.78"
                                           TextWrapping="Wrap" />
                                <ListView ItemsSource="{x:Bind TriggerViewModel.TriggerVolumes, Mode=OneWay}"
                                          SelectedItem="{x:Bind TriggerViewModel.SelectedTrigger, Mode=TwoWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4" Padding="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding TriggerType}" Opacity="0.72" />
                                                <TextBlock Text="{Binding BoundsText}" Opacity="0.72" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Trigger Inspector" />
                            <TextBlock Text="{x:Bind TriggerViewModel.SelectedTriggerName, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind TriggerViewModel.SelectedTriggerType, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind TriggerViewModel.SelectedTriggerBoundsText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind TriggerViewModel.SelectedTriggerScriptText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Minimap">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Minimap Layers" />
                                <TextBlock Opacity="0.78"
                                           TextWrapping="Wrap"
                                           Text="Inspect minimap textures, materials, and notes." />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Spacing="8">
                                <Button Content="Load Minimap"
                                        Click="LoadWorldData_Click" />
                                <TextBlock Text="{x:Bind MinimapViewModel.StatusText, Mode=OneWay}"
                                           Opacity="0.78"
                                           TextWrapping="Wrap" />
                                <ListView ItemsSource="{x:Bind MinimapViewModel.MinimapLayers, Mode=OneWay}"
                                          SelectedItem="{x:Bind MinimapViewModel.SelectedMinimap, Mode=TwoWay}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="4" Padding="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding TexturePath}" Opacity="0.72" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding MaterialPath}" Opacity="0.72" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Minimap Inspector" />
                            <TextBlock Text="{x:Bind MinimapViewModel.SelectedMinimapName, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind MinimapViewModel.SelectedMinimapTexturePath, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind MinimapViewModel.SelectedMinimapMaterialPath, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind MinimapViewModel.SelectedMinimapNotes, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>
