<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.WorldEditor.WorldGeometryEditor.TransformGizmoControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Transform Gizmo" />

        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="Position" />
            <TextBox Text="0, 0, 0" />
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="6">
            <TextBlock Text="Rotation" />
            <TextBox Text="0, 0, 0" />
        </StackPanel>

        <StackPanel Grid.Row="3" Spacing="6">
            <TextBlock Text="Scale" />
            <TextBox Text="1, 1, 1" />
        </StackPanel>
    </Grid>
</UserControl>

