<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.WorldEditor.WorldGeometryViewer.GeometryPreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Geometry Preview" />
            <TextBlock Opacity="0.78"
                       TextWrapping="Wrap"
                       Text="Show mesh metadata, zone bounds, and selected item details." />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="10">
                <TextBlock FontWeight="SemiBold"
                           Text="Selected Geometry" />
                <TextBlock Text="{x:Bind ViewModel.SelectedGeometry.Name, Mode=OneWay}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.SelectedGeometry.TransformText, Mode=OneWay}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.SelectedGeometry.BoundsText, Mode=OneWay}"
                           TextWrapping="Wrap" />
                <TextBlock FontWeight="SemiBold"
                           Text="Zone Bounds" />
                <TextBlock Text="{x:Bind ViewModel.ZoneBoundsText, Mode=OneWay}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

