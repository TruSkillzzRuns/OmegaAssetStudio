<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MFL.Controls.Viewport3DControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Background="#121620"
          PointerPressed="RootGrid_PointerPressed"
          PointerMoved="RootGrid_PointerMoved"
          PointerReleased="RootGrid_PointerReleased"
          PointerWheelChanged="RootGrid_PointerWheelChanged"
          SizeChanged="RootGrid_SizeChanged">
        <SwapChainPanel x:Name="RenderPanel" />
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="12"
                Padding="10"
                CornerRadius="10"
                Background="#AA0F1420">
            <StackPanel Spacing="2">
                <TextBlock x:Name="ActiveMeshTextBlock"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock x:Name="HintTextBlock"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="#D9FFFFFF" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

