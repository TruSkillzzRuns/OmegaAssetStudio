<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.ObjectsWorkspace.Views.ObjectsWorkspaceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:hex="using:OmegaAssetStudio.WinUI.Modules.ObjectsWorkspace.HexEditor"
    mc:Ignorable="d">
    <Grid Padding="12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Text="Hex Editor" />
            <TextBlock Opacity="0.76"
                       TextWrapping="Wrap"
                       Text="Open a UPK, inspect the export bytes, edit the hex text, then apply and save a rebuilt package." />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Open UPK"
                        Click="OpenUpkButton_Click" />
                <Button Content="Apply To Export"
                        Command="{Binding ApplyHexChangesCommand}" />
                <Button Content="Save Rebuilt UPK"
                        Click="SaveUpkButton_Click" />
                <TextBlock VerticalAlignment="Center"
                           Opacity="0.72"
                           Text="{Binding StatusText}" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="12"
                    CornerRadius="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Exports" />
                        <TextBlock Opacity="0.72"
                                   TextWrapping="Wrap"
                                   Text="{Binding PackageSummary}" />
                    </StackPanel>
                    <ListView x:Name="ExportsList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              SelectionChanged="ExportsList_SelectionChanged"
                              ItemsSource="{Binding Exports}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding ObjectName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ClassName}"
                                                   Opacity="0.72"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SerialSize}"
                                               Margin="12,0,0,0"
                                               Opacity="0.72" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Padding="0"
                    CornerRadius="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <hex:HexEditorView x:Name="HexEditorPanel" />
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="12"
                CornerRadius="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <TextBlock TextWrapping="Wrap"
                       Text="Select an export on the left to load its raw bytes into the hex editor. Apply commits edited bytes back into the loaded package, and Save writes a rebuilt UPK." />
        </Border>
    </Grid>
</UserControl>
