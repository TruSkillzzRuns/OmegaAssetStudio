<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.ObjectsWorkspace.TfcManifestEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:OmegaAssetStudio.TfcManifest"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="ManifestPathBox"
                         Width="520"
                         PlaceholderText="Select TextureFileCacheManifest.bin..."
                         Text="{Binding ManifestPath, Mode=TwoWay}" />
                <Button Content="Open Manifest"
                        Click="OpenManifestButton_Click" />
                <Button Content="Save Manifest"
                        Click="SaveManifestButton_Click" />
            </StackPanel>
            <TextBlock Text="{Binding StatusText}"
                       Opacity="0.8"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="12"
                    CornerRadius="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="{Binding PackageNameSortLabel}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="PackageNameHeader_Click" />
                        <TextBlock Grid.Column="1" Text="TextureName" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="TfcFileName" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="ChunkIndex" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="4" Text="Offset" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="5" Text="Size" FontWeight="SemiBold" />
                    </Grid>

                    <ListView x:Name="EntriesList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              ItemsSource="{Binding Entries}"
                              SelectionChanged="EntriesList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:TfcManifestEntry">
                                <Grid Padding="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind PackageName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind TextureName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind TfcFileName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind ChunkIndex, Mode=OneWay}" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind Offset, Mode=OneWay}" />
                                    <TextBlock Grid.Column="5" Text="{x:Bind Size, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Padding="12"
                    CornerRadius="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Entry Inspector" />
                        <StackPanel Spacing="6">
                            <TextBlock Text="PackageName" />
                            <TextBox Text="{Binding SelectedEntry.PackageName, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="TextureName" />
                            <TextBox Text="{Binding SelectedEntry.TextureName, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="TfcFileName" />
                            <TextBox Text="{Binding SelectedEntry.TfcFileName, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="ChunkIndex" />
                            <NumberBox Value="{Binding SelectedEntry.ChunkIndex, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Offset" />
                            <NumberBox Value="{Binding SelectedEntry.Offset, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Size" />
                            <NumberBox Value="{Binding SelectedEntry.Size, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Apply Changes"
                                    Click="ApplyChangesButton_Click" />
                            <Button Content="Add Entry"
                                    Click="AddEntryButton_Click" />
                            <Button Content="Remove Entry"
                                    Click="RemoveEntryButton_Click" />
                        </StackPanel>
                        <Button Content="{Binding ValidationSortLabel}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Margin="0,8,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="ValidationHeader_Click" />
                        <ListView ItemsSource="{Binding ValidationResults}"
                                  MaxHeight="240">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="12"
                CornerRadius="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Injection Tools" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Inject Entries From File..."
                            Click="InjectEntriesFileButton_Click" />
                    <Button Content="Inject Entries From Migration Output"
                            Click="InjectEntriesFromMigrationButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

