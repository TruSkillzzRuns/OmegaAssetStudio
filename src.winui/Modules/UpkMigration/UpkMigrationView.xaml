<Page
    x:Class="OmegaAssetStudio.WinUI.Modules.UpkMigration.UpkMigrationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:OmegaAssetStudio.WinUI.Modules.UpkMigration"
    mc:Ignorable="d">

    <TabView Padding="20">
        <TabViewItem Header="Migration">
            <Grid Padding="0" RowDefinitions="Auto,*" ColumnDefinitions="300,*,360" ColumnSpacing="12">
                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Spacing="8">
                    <TextBlock Text="UPK Migration"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Batch migrate Marvel Heroes 1.48 UPKs into new output packages while extracting neutral mesh, texture, animation, and material data."
                               TextWrapping="Wrap"
                               Opacity="0.85" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12">
                        <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Workspace" FontSize="18" FontWeight="SemiBold" />
                                <Button Content="Select 1.48 UPKs..." Command="{Binding SelectUpksCommand}" />
                                <Button Content="Start Migration" Command="{Binding StartMigrationCommand}" />
                                <TextBox Header="Output directory"
                                         Text="{Binding OutputDirectory, Mode=TwoWay}"
                                         PlaceholderText="Enter or browse the migration output folder." />
                                <Button Content="Browse..." Command="{Binding BrowseOutputDirectoryCommand}" />
                                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Value="{Binding OverallProgress}"
                                             Height="8" />
                                <TextBlock Text="{Binding ProgressText}" TextWrapping="Wrap" Opacity="0.8" />
                            </StackPanel>
                        </Border>

                        <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Migration Notes" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Source UPKs are left untouched. Output packages are written to the chosen folder and a neutral migration manifest is written alongside each output package."
                                           TextWrapping="Wrap"
                                           Opacity="0.85" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12">
                        <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Migration Jobs" FontSize="18" FontWeight="SemiBold" />
                                <Grid ColumnDefinitions="2.5*,*,*,*,*,*,*,*" ColumnSpacing="8">
                                    <TextBlock Text="Source UPK" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="Status" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="Analyze %" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="Migrate %" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="Meshes" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="5" Text="Textures" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="6" Text="Animations" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="7" Text="Materials" FontWeight="SemiBold" />
                                </Grid>
                                <ListView ItemsSource="{Binding Jobs}"
                                          SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                                          SelectionMode="Single"
                                          MinHeight="280">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="2.5*,*,*,*,*,*,*,*" ColumnSpacing="8" Padding="0,6">
                                                <TextBlock Text="{Binding SourceUpkPath}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Status}" />
                                                <TextBlock Grid.Column="2" Text="{Binding AnalyzeProgressText}" />
                                                <TextBlock Grid.Column="3" Text="{Binding MigrateProgressText}" />
                                                <TextBlock Grid.Column="4" Text="{Binding MeshCount}" />
                                                <TextBlock Grid.Column="5" Text="{Binding TextureCount}" />
                                                <TextBlock Grid.Column="6" Text="{Binding AnimationCount}" />
                                                <TextBlock Grid.Column="7" Text="{Binding MaterialCount}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Selected Job Details" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedJobDetails}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Grid.Row="1" Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12">
                        <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Log" FontSize="18" FontWeight="SemiBold" />
                                <ListView ItemsSource="{Binding LogEntries}" MinHeight="260">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Timestamp}" FontSize="12" Opacity="0.7" />
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Level}" FontSize="12" Opacity="0.7" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Results" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ResultsSummaryText}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Thanos Raid" FontSize="18" FontWeight="SemiBold" />
                                <ComboBox SelectedIndex="{Binding CurrentModeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="Standard" />
                                    <ComboBoxItem Content="Thanos Raid" />
                                </ComboBox>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Batch Analyze" Command="{Binding AnalyzeThanosCommand}" />
                                    <Button Content="Batch Migrate" Command="{Binding MigrateThanosCommand}" />
                                </StackPanel>

                                <TextBox Header="Texture manifest folder"
                                         Text="{Binding TextureManifestDirectory, Mode=TwoWay}"
                                         PlaceholderText="Select the 1.52 client folder that contains TextureFileCacheManifest.bin." />

                                <Button Content="Browse Manifest Folder..." Command="{Binding BrowseTextureManifestDirectoryCommand}" />
                                <Button Content="Update Texture Manifest" Command="{Binding UpdateTextureManifestCommand}" />

                                <TextBlock Text="{Binding ThanosReport.FilePath}"
                                           TextWrapping="Wrap"
                                           Opacity="0.85" />

                                <TextBlock Text="Steps" FontWeight="SemiBold" />
                                <ListView ItemsSource="{Binding ThanosSteps}" MinHeight="140">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Status}" FontSize="12" Opacity="0.75" />
                                                <TextBlock Text="{Binding Reason}" FontSize="12" Opacity="0.75" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock Text="Findings" FontWeight="SemiBold" />
                                <ListView ItemsSource="{Binding ThanosReport.Findings}" MinHeight="140">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Severity}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Category}" FontSize="12" Opacity="0.75" />
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding RecommendedAction}" FontSize="12" Opacity="0.75" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </TabViewItem>
        <TabViewItem Header="Prototype Merger">
            <local:ThanosPrototypeMergerView DataContext="{Binding PrototypeMerger}" />
        </TabViewItem>
    </TabView>
</Page>

