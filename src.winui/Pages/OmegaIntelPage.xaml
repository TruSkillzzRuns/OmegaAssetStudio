<Page
    x:Class="OmegaAssetStudio.WinUI.Pages.OmegaIntelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="ms-appx:///Assets/OmegaIntelBackground.png"
                        Stretch="UniformToFill"
                        AlignmentX="Center"
                        AlignmentY="Center"
                        Opacity="0.28" />
        </Grid.Background>

        <Border Background="#D1141A1F" />

        <ScrollViewer Margin="24,20,24,24"
                      VerticalScrollBarVisibility="Auto">
            <Grid RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                           Text="Omega Intelligence Engine" />
                <TextBlock Opacity="0.78"
                           FontSize="16"
                           Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                           TextWrapping="Wrap"
                           Text="Read-only analyzer for Marvel Heroes Omega content. It scans the game folder, classifies files, inspects supported assets, builds a knowledge graph, and exports reports without touching game data." />
            </StackPanel>

            <Border Grid.Row="1"
                    Padding="14"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="StatusTextBlock"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                               TextWrapping="Wrap"
                               Text="Status: ready." />
                    <ProgressBar x:Name="ScanProgressBar"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="False"
                                 Value="0"
                                 Height="6" />
                    <TextBlock x:Name="ProgressTextBlock"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                               TextWrapping="Wrap"
                               Text="Progress: idle" />
                    <TextBlock x:Name="FoldersTextBlock"
                               FontSize="16"
                               Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="SummaryTextBlock"
                               FontSize="16"
                               Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="ValidationTextBlock"
                               FontSize="16"
                               Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                               TextWrapping="Wrap"
                               Text="Validation: not run." />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.8*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Border Padding="18"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="20"
                                       Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="Scan &amp; Analyze" />
                        <TextBox x:Name="RootPathBox"
                                 Header="Game Folder"
                                 PlaceholderText="Select the Marvel Heroes Omega root folder..."
                                 TextWrapping="Wrap" />
                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Button Content="Browse Folder"
                                    MinHeight="42"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="BrowseFolderButton_Click" />
                            <Button Grid.Column="1"
                                    Content="Scan Folder"
                                    MinHeight="42"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="ScanButton_Click" />
                            <Button Grid.Row="1"
                                    Content="Export Reports"
                                    MinHeight="42"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="ExportReportsButton_Click" />
                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Content="Open OmegaIntel"
                                    MinHeight="42"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Click="OpenOmegaIntelButton_Click" />
                            <Button Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Content="Scan UPK"
                                    MinHeight="42"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding ScanUpkCommand}" />
                        </Grid>
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="16"
                                       Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="Reports" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="OpenReportsFolderButton_Click">
                                    <TextBlock Text="Open Reports Folder"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Column="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="OpenLatestMarkdownButton_Click">
                                    <TextBlock Text="Open Latest Markdown"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Column="2"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="OpenLatestHtmlButton_Click">
                                    <TextBlock Text="Open Latest HTML"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="OpenLatestJsonButton_Click">
                                    <TextBlock Text="Open Latest JSON"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="OpenLatestCsvButton_Click">
                                    <TextBlock Text="Open Latest CSV"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                            </Grid>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="16"
                                       Foreground="{ThemeResource OmegaAssetStudio.DarkSurfaceTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="Focused Analyzer Runs" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button Click="RunFileSystemAnalysisButton_Click"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center">
                                    <TextBlock Text="Run File System Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Column="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunUpkAnalysisButton_Click">
                                    <TextBlock Text="Run UPK Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunTfcAnalysisButton_Click">
                                    <TextBlock Text="Run TFC Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunTextureAnalysisButton_Click">
                                    <TextBlock Text="Run Texture Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="2"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunSkeletonAnalysisButton_Click">
                                    <TextBlock Text="Run Skeleton Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="2"
                                        Grid.Column="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunAnimationAnalysisButton_Click">
                                    <TextBlock Text="Run Animation Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="3"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunCharacterAnalysisButton_Click">
                                    <TextBlock Text="Run CharacterDefinition Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="3"
                                        Grid.Column="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunUiAnalysisButton_Click">
                                    <TextBlock Text="Run UI Analysis"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="4"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="RunExecutableAnalysisButton_Click">
                                    <TextBlock Text="Run EXE Analysis (Read-Only)"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                                <Button Grid.Row="4"
                                        Grid.Column="1"
                                        MinHeight="54"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Click="BuildKnowledgeGraphButton_Click">
                                    <TextBlock Text="Build Knowledge Graph"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                            </Grid>
                        </StackPanel>
                        <Border Padding="12"
                                CornerRadius="12"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock FontSize="16"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           Text="UPK Migration Readiness" />
                                <TextBlock FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="Scan one UPK and export package metadata, export breakdowns, unresolved reference health, dependency graph info, and readiness recommendations into a dedicated desktop folder." />
                                <TextBox x:Name="MigrationReadinessUpkBox"
                                         Header="UPK Path"
                                         PlaceholderText="Choose a single .upk file to inspect..."
                                         TextWrapping="Wrap" />
                                <Grid ColumnSpacing="8"
                                      RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Browse UPK"
                                            MinHeight="42"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="BrowseMigrationReadinessUpkButton_Click" />
                                    <Button Grid.Column="1"
                                            Content="Scan &amp; Export Readiness"
                                            MinHeight="42"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="ExportMigrationReadinessButton_Click" />
                                </Grid>
                                <TextBox x:Name="MigrationReadinessOutputBox"
                                         Header="Output Folder"
                                         TextWrapping="Wrap"
                                         Text="C:\Users\TruSkillzzRuns\Desktop\OmegaIntel_MigrationReadiness" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Browse Output Folder"
                                            MinHeight="42"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Click="BrowseMigrationReadinessOutputButton_Click" />
                                    <TextBlock Grid.Column="1"
                                               x:Name="MigrationReadinessStatusTextBlock"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="Readiness export: idle." />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           Text="File System" />
                                <TextBlock x:Name="FilesCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="DirectoryCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="EntropyCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           Text="UPK / Cache" />
                                <TextBlock x:Name="UpkCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="TfcCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="ManifestCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="TextureCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="MeshCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="AnimCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="ResolvedCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="CacheBackedCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           Text="Heuristics" />
                                <TextBlock x:Name="UiCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="CharacterCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="ExeCountTextBlock"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="18"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="Scan Results" />
                            <Grid ColumnSpacing="8"
                                  RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ScanSearchBox"
                                         PlaceholderText="Search UPKs, files, paths..."
                                         TextChanged="ScanSearchBox_TextChanged" />
                                <CheckBox x:Name="ScanUpkOnlyCheckBox"
                                          Grid.Column="1"
                                          Content="UPK only"
                                          VerticalAlignment="Center"
                                          Checked="ScanUpkOnlyCheckBox_Changed"
                                          Unchecked="ScanUpkOnlyCheckBox_Changed" />
                            </Grid>
                            <TextBlock x:Name="ScanFilterStatusTextBlock"
                                       TextWrapping="Wrap"
                                       Opacity="0.78" />
                        </StackPanel>
                        <ListView x:Name="ScanResultsListView"
                                  Grid.Row="1"
                                  SelectionChanged="ScanResultsListView_SelectionChanged"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10"
                                            Margin="0,0,0,8"
                                            CornerRadius="10"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Classification}"
                                                       Opacity="0.82"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Summary}"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Path}"
                                                       Opacity="0.62"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="18"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="Inspector" />
                            <TextBlock x:Name="SelectedPathTextBlock"
                                       TextWrapping="Wrap"
                                       Opacity="0.8"
                                       Text="Select a file to inspect it here." />
                        </StackPanel>
                        <ListView x:Name="InspectorListView"
                                  Grid.Row="1"
                                  IsHitTestVisible="False"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel Grid.Row="2" Spacing="6">
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="Entity Selector" />
                            <TextBox x:Name="EntitySearchBox"
                                     PlaceholderText="Search graph entities..."
                                     TextChanged="EntitySearchBox_TextChanged" />
                            <ComboBox x:Name="GraphKindFilterComboBox"
                                      HorizontalContentAlignment="Stretch"
                                      MaxDropDownHeight="320"
                                      SelectionChanged="GraphKindFilterComboBox_SelectionChanged" />
                            <ComboBox x:Name="EntitySelectorComboBox"
                                      DisplayMemberPath="Label"
                                      HorizontalContentAlignment="Stretch"
                                      MaxDropDownHeight="320"
                                      SelectionChanged="EntitySelectorComboBox_SelectionChanged"
                                      PlaceholderText="Choose a graph entity...">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,2" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <ListView x:Name="EntityInspectorListView"
                                  Grid.Row="3"
                                  IsHitTestVisible="False"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Grid.Row="4"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Knowledge Graph" />
                        <ListView x:Name="GraphListView"
                                  Grid.Row="5"
                                  IsHitTestVisible="False"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="3"
                    Padding="18"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="Status &amp; Logs" />
                    <ListView x:Name="LogListView"
                              Grid.Row="1"
                              IsHitTestVisible="False"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

