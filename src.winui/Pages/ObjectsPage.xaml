<Page
    x:Class="OmegaAssetStudio.WinUI.Pages.ObjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:objectsWorkspace="using:OmegaAssetStudio.WinUI.Modules.ObjectsWorkspace"
    xmlns:objectsWorkspaceViews="using:OmegaAssetStudio.WinUI.Modules.ObjectsWorkspace.Views"
    xmlns:models="using:OmegaAssetStudio.WinUI.Models"
    mc:Ignorable="d">

    <Grid Margin="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Text="Objects Workspace" />
            <TextBlock Opacity="0.78"
                       TextWrapping="Wrap"
                       Text="First live migration target. This page mirrors the original left object tree and right inspector tabs from the WinForms app." />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Open UPK"
                        Click="OpenUpkButton_Click" />
                <TextBlock x:Name="CurrentPathText"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           TextWrapping="Wrap"
                           Text="No UPK loaded yet." />
            </StackPanel>
        </StackPanel>

        <controls:TabView Grid.Row="1" x:Name="WorkspaceTabs">
            <controls:TabViewItem Header="Objects">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ObjectsPaneColumn" Width="860" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="12"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Objects" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <TextBlock VerticalAlignment="Center"
                                               Opacity="0.78"
                                               Text="Browser Width" />
                                    <Slider x:Name="ObjectsPaneWidthSlider"
                                            Width="220"
                                            Minimum="680"
                                            Maximum="1300"
                                            Value="860"
                                            ValueChanged="ObjectsPaneWidthSlider_ValueChanged" />
                                </StackPanel>
                                <AutoSuggestBox x:Name="FilterBox"
                                                PlaceholderText="Filter exports, imports, and packages..."
                                                TextChanged="FilterBox_TextChanged" />
                            </StackPanel>

                            <controls:TreeView Grid.Row="1"
                                               x:Name="ObjectsTree"
                                               SelectionMode="Single"
                                               SelectionChanged="ObjectsTree_SelectionChanged">
                                <controls:TreeView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </controls:TreeView.ItemTemplate>
                            </controls:TreeView>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="14"
                                CornerRadius="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="InspectorTitle"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Inspector" />
                                <TextBlock x:Name="InspectorSubtitle"
                                           Opacity="0.78"
                                           TextWrapping="Wrap"
                                           Text="Select an object on the left to inspect its metadata, names, imports, exports, and parsed properties." />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="CopyPathButton"
                                            Content="Copy Path"
                                            Click="CopyPathButton_Click"
                                            IsEnabled="False" />
                                    <Button x:Name="OpenHexButton"
                                            Content="Open Hex"
                                            Click="OpenHexButton_Click"
                                            IsEnabled="False" />
                                    <Button x:Name="MeshActionButton"
                                            Content="Mesh Details"
                                            Click="MeshActionButton_Click"
                                            IsEnabled="False" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <controls:TabView Grid.Row="1" x:Name="InspectorTabs">
                            <controls:TabViewItem Header="File">
                                <ScrollViewer Padding="16">
                                    <StackPanel Spacing="12">
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Package File Summary" />
                                        <TextBlock TextWrapping="Wrap"
                                                   Text="This area will replace the old PropertyGrid-based file inspector with WinUI cards and grouped metadata." />
                                        <ListView ItemsSource="{x:Bind FileRows, Mode=OneWay}">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,4" />
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </ScrollViewer>
                            </controls:TabViewItem>

                            <controls:TabViewItem Header="Properties">
                                <Grid Padding="16" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock TextWrapping="Wrap"
                                               Text="The current WinForms property tree will move here. This first pass shows summary rows for the selected item." />
                                    <ListView Grid.Row="1"
                                              ItemsSource="{x:Bind PropertyRows, Mode=OneWay}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,4" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                        <AutoSuggestBox x:Name="PropertyFilterBox"
                                                        Width="340"
                                                        PlaceholderText="Filter property tree..."
                                                        TextChanged="PropertyFilterBox_TextChanged" />
                                        <Button x:Name="CopyPropertyButton"
                                                Content="Copy Property"
                                                Click="CopyPropertyButton_Click"
                                                IsEnabled="False" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3"
                                                Spacing="6">
                                        <TextBlock x:Name="PropertySelectionTitle"
                                                   FontWeight="SemiBold"
                                                   Text="Property Details" />
                                        <ListView x:Name="PropertyDetailList"
                                                  MaxHeight="160"
                                                  ItemsSource="{x:Bind PropertyDetailRows, Mode=OneWay}">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,4" />
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                    <controls:TreeView Grid.Row="4"
                                                       x:Name="PropertiesTree"
                                                       SelectionMode="Single"
                                                       SelectionChanged="PropertiesTree_SelectionChanged">
                                        <controls:TreeView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </controls:TreeView.ItemTemplate>
                                    </controls:TreeView>
                                </Grid>
                            </controls:TabViewItem>

                            <controls:TabViewItem Header="Names">
                                <Grid Padding="16" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="NamesTabSubtitle"
                                               Opacity="0.78"
                                               TextWrapping="Wrap"
                                               Text="Package name table preview." />
                                    <ListView Grid.Row="1"
                                              ItemsSource="{x:Bind NameRows, Mode=OneWay}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,4" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </controls:TabViewItem>

                            <controls:TabViewItem Header="Imports">
                                <Grid Padding="16" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ImportsTabSubtitle"
                                               Opacity="0.78"
                                               TextWrapping="Wrap"
                                               Text="Package import table preview." />
                                    <ListView Grid.Row="1"
                                              ItemsSource="{x:Bind ImportRows, Mode=OneWay}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,4" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </controls:TabViewItem>

                            <controls:TabViewItem Header="Exports">
                                <Grid Padding="16" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ExportsTabSubtitle"
                                               Opacity="0.78"
                                               TextWrapping="Wrap"
                                               Text="Package export table preview." />
                                    <ListView Grid.Row="1"
                                              ItemsSource="{x:Bind ExportRows, Mode=OneWay}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,4" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </controls:TabViewItem>
                        </controls:TabView>
                    </Grid>
                </Grid>
            </controls:TabViewItem>

            <controls:TabViewItem x:Name="HexEditorTab" Header="Hex Editor">
                <objectsWorkspaceViews:ObjectsWorkspaceView x:Name="HexEditorWorkspace" />
            </controls:TabViewItem>

            <controls:TabViewItem Header="TFC Manifest Editor">
                <objectsWorkspace:TfcManifestEditorView />
            </controls:TabViewItem>
        </controls:TabView>
    </Grid>
</Page>

