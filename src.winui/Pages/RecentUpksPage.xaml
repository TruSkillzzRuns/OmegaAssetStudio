<Page
    x:Class="OmegaAssetStudio.WinUI.Pages.RecentUpksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:OmegaAssetStudio.WinUI.Models"
    mc:Ignorable="d">

    <ScrollViewer Margin="24,20,24,24"
                  VerticalScrollBarVisibility="Auto">
        <Grid RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Text="Recent UPKs" />
                <TextBlock Opacity="0.78"
                           TextWrapping="Wrap"
                           Text="Quick jump list for the last UPK files opened in Objects, Mesh, or other workspace handoffs." />
            </StackPanel>

            <Border Grid.Row="1"
                    Padding="14"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Refresh"
                                Click="RefreshButton_Click" />
                        <Button Content="Clear Recent"
                                Click="ClearButton_Click" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Text="No recent UPKs loaded yet." />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Padding="16"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Recent package history"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <ListView x:Name="RecentList"
                              Grid.Row="1"
                              ItemsSource="{x:Bind RecentItems, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:RecentUpkEntry">
                                <Border Padding="12"
                                        Margin="0,0,0,12"
                                        CornerRadius="12"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Text="{x:Bind DisplayTitle}" />
                                        <TextBlock Opacity="0.82"
                                                   TextWrapping="Wrap"
                                                   Text="{x:Bind UpkPath}" />
                                        <TextBlock Opacity="0.72"
                                                   TextWrapping="Wrap"
                                                   Text="{x:Bind Summary}" />
                                        <Grid ColumnSpacing="8" RowSpacing="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Row="0"
                                                    Grid.Column="0"
                                                    Click="OpenInObjectsButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Open in Objects"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Button>
                                            <Button Grid.Row="0"
                                                    Grid.Column="1"
                                                    Click="OpenInMeshButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Open in Mesh"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Button>
                                            <Button Grid.Row="0"
                                                    Grid.Column="2"
                                                    Click="OpenInTexturesButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Open in Textures"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Button>
                                            <Button Grid.Row="0"
                                                    Grid.Column="3"
                                                    Click="SendToRetargetButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Send to Retarget"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Button>
                                            <Button Grid.Row="1"
                                                    Grid.Column="0"
                                                    Click="OpenInOmegaIntelButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Open in Omega Intel"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Button>
                                            <Button Grid.Row="1"
                                                    Grid.Column="1"
                                                    Click="SendToMeshAButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Send to Mesh A"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Button>
                                            <Button Grid.Row="1"
                                                    Grid.Column="2"
                                                    Click="SendToMeshBButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="Send to Mesh B"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Button>
                                        </Grid>
                                        <TextBlock Opacity="0.6"
                                                   TextWrapping="Wrap"
                                                   Text="{x:Bind LastUsedText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

