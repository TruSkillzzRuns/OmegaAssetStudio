<Page
    x:Class="OmegaAssetStudio.WinUI.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Text="Diagnostics" />
            <TextBlock Opacity="0.78"
                       TextWrapping="Wrap"
                       Text="Inspect live app state, renderer state, and recent logs without guessing." />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8">
            <Button Content="Refresh"
                    Click="RefreshButton_Click" />
            <Button Content="Run Material Probe"
                    Click="RunMaterialProbeButton_Click" />
            <Button Content="Copy Snapshot"
                    Click="CopySnapshotButton_Click" />
            <Button Content="Copy Logs"
                    Click="CopyLogsButton_Click" />
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
                <Border Padding="16"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Runtime State" />
                        <TextBlock x:Name="RuntimeStateText"
                                   TextWrapping="Wrap"
                                   Opacity="0.85"
                                   FontFamily="Consolas" />
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Material Probe" />
                        <TextBox x:Name="ProbeBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 MinHeight="220" />
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Snapshot" />
                        <TextBox x:Name="SnapshotBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 MinHeight="240" />
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Recent Logs" />
                        <TextBox x:Name="LogsBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 MinHeight="320" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

